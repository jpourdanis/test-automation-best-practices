{
  "mutate": ["index.js"],
  "testRunner": "jest",
  "jest": {
    "projectType": "custom",
    "configFile": "jest.config.js"
  },
  "reporters": ["clear-text", "html", "progress"],
  "htmlReporter": {
    "fileName": "reports/mutation.html"
  },
  "thresholds": {
    "high": 80,
    "low": 70,
    "break": 70
  },
  "concurrency": 4,
  "timeoutMS": 30000,
  "ignoreStatic": true
}
