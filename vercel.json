{
  "version": 2,
  "rewrites": [
    {
      "source": "/api-docs/swagger-ui.css",
      "destination": "https://cdnjs.cloudflare.com/ajax/libs/swagger-ui/4.15.5/swagger-ui.min.css"
    },
    {
      "source": "/api-docs/swagger-ui-bundle.js",
      "destination": "https://cdnjs.cloudflare.com/ajax/libs/swagger-ui/4.15.5/swagger-ui-bundle.min.js"
    },
    {
      "source": "/api-docs/swagger-ui-standalone-preset.js",
      "destination": "https://cdnjs.cloudflare.com/ajax/libs/swagger-ui/4.15.5/swagger-ui-standalone-preset.min.js"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/api-docs(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/openapi.json",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
