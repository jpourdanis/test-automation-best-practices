{
  "name": "color-picker-native",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:dev:ios": "eas build --platform ios --profile development --non-interactive",
    "build:dev:android": "eas build --platform android --profile development --non-interactive",
    "build:dev:all": "eas build --platform all --profile development --non-interactive",
    "workflow:dev": "eas workflow:run .eas/workflows/create-development-builds.yml",
    "build:ios": "eas build --platform ios --profile simulator --non-interactive",
    "build:android": "eas build --platform android --profile preview --non-interactive",
    "build:all": "eas build --platform all --profile preview --non-interactive",
    "appium:install-drivers": "appium driver install xcuitest",
    "appium:install-drivers:android": "appium driver install uiautomator2",
    "test:ios": "wdio run e2e/wdio.ios.conf.ts",
    "test:unit": "cross-env JEST_JUNIT_OUTPUT_DIR=allure-results JEST_JUNIT_OUTPUT_NAME=junit-mobile-unit-tests.xml jest --coverage"
  },
  "dependencies": {
    "@react-native-community/slider": "5.0.1",
    "@react-native-picker/picker": "2.11.1",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.20",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-localization": "~17.0.8",
    "expo-status-bar": "~3.0.9",
    "i18next": "^26.0.6",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-i18next": "^17.0.4",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "~0.8.1",
    "reanimated-color-picker": "^4.2.0"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.0.1",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.0",
    "@wdio/appium-service": "^9.0.0",
    "@wdio/cli": "^9.0.0",
    "@wdio/globals": "^9.0.0",
    "@wdio/local-runner": "^9.0.0",
    "@wdio/mocha-framework": "^9.0.0",
    "@wdio/spec-reporter": "^9.0.0",
    "@wdio/types": "^9.0.0",
    "appium": "^3.3.1",
    "cross-env": "^7.0.3",
    "jest": "^29.7.0",
    "jest-expo": "~52.0.3",
    "jest-junit": "^16.0.0",
    "react-test-renderer": "^19.2.5",
    "ts-node": "^10.9.0",
    "typescript": "~5.9.2",
    "webdriverio": "^9.0.0"
  },
  "private": true
}
