{
  "name": "test-automation-best-practices",
  "version": "1.0.0",
  "private": true,
  "overrides": {
    "nth-check": "^2.1.1",
    "postcss": "^8.4.31",
    "serialize-javascript": "^7.0.5",
    "@tootallnate/once": "^3.0.1",
    "picomatch": "^2.3.2",
    "lint-staged": {
      "picomatch": "^4.0.4"
    },
    "qs": "^6.14.1",
    "rollup": "^2.79.2",
    "semver": "^7.5.3",
    "tough-cookie": "^4.1.3",
    "yaml": "^2.2.2",
    "webpack": "^5.94.0",
    "ws": "^8.17.1",
    "lodash": "^4.18.1",
    "lodash-es": "^4.18.1",
    "node-forge": "^1.3.0",
    "js-yaml": "^4.1.1"
  },
  "dependencies": {
    "@playwright/test": "^1.59.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.0.0",
    "babel-plugin-istanbul": "^6.1.1",
    "cross-env": "^7.0.3",
    "customize-cra": "^1.0.0",
    "i18next": "^26.0.6",
    "i18next-browser-languagedetector": "^8.2.1",
    "nyc": "^18.0.0",
    "react": "^19.2.5",
    "react-app-rewired": "^2.2.1",
    "react-dom": "^19.2.5",
    "react-i18next": "^17.0.4",
    "react-scripts": "5.0.1",
    "typescript": "^6.0.2"
  },
  "scripts": {
    "prepare": "husky",
    "lint": "eslint --ext .ts,.tsx,.js,.jsx src e2e performance && npx prettier --check .",
    "lint:fix": "eslint --fix --ext .ts,.tsx,.js,.jsx src e2e performance && npx prettier --write .",
    "format": "npx prettier --write .",
    "start": "react-app-rewired start",
    "build": "react-app-rewired build",
    "test": "cross-env npx playwright test '^(?!.*visual\\.spec\\.ts).*\\.spec\\.ts$'",
    "test:e2e:prod": "cross-env npx playwright test '^(?!.*visual\\.spec\\.ts).*\\.spec\\.ts$'",
    "test:bdd": "npx bddgen && npx playwright test --project=BDD",
    "test:cross-browser": "cross-env CROSS_BROWSER=true npx playwright test e2e/tests/cross-browser.spec.ts",
    "coverage": "npm run test && nyc report --reporter=text",
    "coverage:check": "nyc check-coverage --lines 80 --functions 80 --branches 80",
    "test:e2e:docker": "docker-compose run --build --rm playwright e2e/tests/visual.spec.ts",
    "test:e2e:docker:update": "docker-compose run --build --rm playwright e2e/tests/visual.spec.ts --update-snapshots",
    "test:visual:percy": "PERCY_TOKEN=$PERCY_TOKEN npx percy exec -- npx playwright test --project=percy e2e/tests/visual.spec.ts",
    "test:api": "npx playwright test e2e/tests/api.spec.ts",
    "test:perf:api:smoke": "TEST_TYPE=smoke k6 run performance/api-performance.spec.ts",
    "test:perf:api:load": "TEST_TYPE=load k6 run performance/api-performance.spec.ts",
    "test:perf:ui:smoke": "K6_BROWSER_ENABLED=true TEST_TYPE=smoke k6 run performance/ui-performance.spec.ts",
    "test:perf:ui:load": "K6_BROWSER_ENABLED=true TEST_TYPE=load k6 run performance/ui-performance.spec.ts",
    "test:perf": "npm run test:perf:ui:smoke",
    "test:api:schemathesis": "docker run --rm schemathesis/schemathesis run http://host.docker.internal:5001/openapi.json",
    "test:unit": "cross-env JEST_JUNIT_OUTPUT_DIR=allure-results JEST_JUNIT_OUTPUT_NAME=junit-frontend-unit-tests.xml react-scripts test --watchAll=false --reporters=default --reporters=jest-junit --coverage",
    "sonar:scan": "sonar-scanner",
    "mutation:frontend": "stryker run",
    "docker:up": "docker-compose up -d --build",
    "security:audit": "npm audit --audit-level=high",
    "security:scan:code": "docker run --rm -v $(pwd):/app aquasec/trivy:0.69.3 fs /app",
    "security:scan:container:app": "docker run --rm -v /var/run/docker.sock:/var/run/docker.sock aquasec/trivy:0.69.3 image test-automation-best-practices-app:latest",
    "security:scan:container:api": "docker run --rm -v /var/run/docker.sock:/var/run/docker.sock -v $(pwd)/.trivyignore:/.trivyignore aquasec/trivy:0.69.3 image --ignorefile /.trivyignore test-automation-best-practices-api:latest",
    "security:scan": "npm run security:audit && npm run security:scan:code",
    "test:browserstack": "cross-env BROWSERSTACK=true browserstack-node-sdk playwright test"
  },
  "eslintConfig": {
    "extends": "react-app"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@cucumber/cucumber": "^12.7.0",
    "@faker-js/faker": "^10.4.0",
    "@percy/cli": "^1.29.0",
    "@percy/playwright": "^1.1.0",
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/jest-runner": "^9.6.0",
    "@testing-library/dom": "^10.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^29.5.14",
    "@types/k6": "^1.7.0",
    "@types/node": "^22.13.10",
    "allure-playwright": "^3.6.0",
    "browserstack-node-sdk": "^1.52.0",
    "http-proxy-middleware": "^3.0.5",
    "husky": "^9.1.7",
    "jest-junit": "^16.0.0",
    "lighthouse": "^13.0.3",
    "lint-staged": "^16.4.0",
    "playwright-bdd": "^8.5.0",
    "playwright-lighthouse": "^4.0.0",
    "sonarqube-scanner": "^4.3.6",
    "zod": "^4.3.6"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "npx prettier --write"
    ],
    "*.{yml,yaml}": [
      "npx prettier --write"
    ],
    "*.{json}": [
      "npx prettier --write"
    ],
    "*.md": [
      "npx prettier --write"
    ]
  },
  "jest": {
    "collectCoverageFrom": [
      "src/**/*.{ts,tsx}",
      "!src/index.tsx",
      "!src/setupTests.ts",
      "!src/react-app-env.d.ts"
    ]
  },
  "nyc": {
    "extension": [
      ".js",
      ".jsx",
      ".ts",
      ".tsx"
    ],
    "exclude": [
      "src/setupProxy.js",
      "src/index.tsx",
      "src/setupTests.ts",
      "src/react-app-env.d.ts"
    ]
  }
}
